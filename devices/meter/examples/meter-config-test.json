{
  "device_name": "three-phase-meter-1",
  "device_type": "electricity-meter",
  "poll_interval_ms": 1000,
  "zmq": {
    "enabled": false
  },
  "logging": {
    "level": "info",
    "format": "json"
  },
  "custom": {
    "thing_model": {
      "model_id": "meter.electricity.three-phase.1.0",
      "model_version": "1.0",
      "device_type": "electricity-meter",
      "manufacturer": "Generic",
      "description": "Three phase electricity meter",
      "properties": [
        {
          "identifier": "voltage_l1",
          "name": "Voltage L1",
          "type": "float",
          "unit": "V",
          "access": "R",
          "range": [
            0,
            400
          ],
          "default_value": 220,
          "description": "Voltage on phase L1"
        },
        {
          "identifier": "voltage_l2",
          "name": "Voltage L2",
          "type": "float",
          "unit": "V",
          "access": "R",
          "range": [
            0,
            400
          ],
          "default_value": 220,
          "description": "Voltage on phase L2"
        },
        {
          "identifier": "voltage_l3",
          "name": "Voltage L3",
          "type": "float",
          "unit": "V",
          "access": "R",
          "range": [
            0,
            400
          ],
          "default_value": 220,
          "description": "Voltage on phase L3"
        },
        {
          "identifier": "current_l1",
          "name": "Current L1",
          "type": "float",
          "unit": "A",
          "access": "R",
          "range": [
            0,
            100
          ],
          "default_value": 10.5,
          "description": "Current on phase L1"
        },
        {
          "identifier": "current_l2",
          "name": "Current L2",
          "type": "float",
          "unit": "A",
          "access": "R",
          "range": [
            0,
            100
          ],
          "default_value": 11.2,
          "description": "Current on phase L2"
        },
        {
          "identifier": "current_l3",
          "name": "Current L3",
          "type": "float",
          "unit": "A",
          "access": "R",
          "range": [
            0,
            100
          ],
          "default_value": 9.8,
          "description": "Current on phase L3"
        },
        {
          "identifier": "active_power",
          "name": "Active Power",
          "type": "float",
          "unit": "W",
          "access": "R",
          "range": [
            0,
            1000000
          ],
          "default_value": 7200,
          "description": "Total active power"
        },
        {
          "identifier": "power_factor",
          "name": "Power Factor",
          "type": "float",
          "unit": "",
          "access": "R",
          "range": [
            0,
            1
          ],
          "default_value": 0.95,
          "description": "Power factor"
        },
        {
          "identifier": "energy_active",
          "name": "Active Energy",
          "type": "float",
          "unit": "kWh",
          "access": "R",
          "range": [
            0,
            100000000
          ],
          "default_value": 12345.6,
          "description": "Total active energy"
        }
      ],
      "events": [
        {
          "identifier": "over_voltage",
          "name": "Over Voltage",
          "level": "WARN",
          "output_params": [
            {
              "identifier": "voltage",
              "name": "Current Voltage",
              "type": "float"
            },
            {
              "identifier": "phase",
              "name": "Phase",
              "type": "string"
            }
          ],
          "description": "Triggered when voltage exceeds threshold"
        },
        {
          "identifier": "over_power",
          "name": "Over Power",
          "level": "WARN",
          "output_params": [
            {
              "identifier": "power",
              "name": "Current Power",
              "type": "float"
            }
          ],
          "description": "Triggered when power exceeds threshold"
        }
      ],
      "rules": [
        {
          "identifier": "over_voltage_l1",
          "name": "Over Voltage Alarm on L1",
          "conditions": [
            {
              "property_identifier": "voltage_l1",
              "operator": ">",
              "value": 250
            }
          ],
          "condition_logic": "and",
          "actions": [
            {
              "trigger_event": {
                "event_identifier": "over_voltage",
                "data": {
                  "voltage": "{{voltage_l1}}",
                  "phase": "L1"
                }
              }
            }
          ],
          "enabled": true
        },
        {
          "identifier": "over_power",
          "name": "Over Power Alarm",
          "conditions": [
            {
              "property_identifier": "active_power",
              "operator": ">",
              "value": 10000
            }
          ],
          "condition_logic": "and",
          "actions": [
            {
              "trigger_event": {
                "event_identifier": "over_power",
                "data": {
                  "current_power": "{{active_power}}"
                }
              }
            }
          ],
          "enabled": true
        }
      ]
    }
  }
}
