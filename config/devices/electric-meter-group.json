            }
          },
          {
            "identifier": "power",
            "name": "Active Power",
            "type": "float",
            "unit": "kW",
            "access": "R",
            "range": [0, 100],
            "default_value": 0,
            "description": "Active power",
            "modbus": {
              "primaryTable": "INPUT_REGISTERS",
              "startingAddress": 2,
