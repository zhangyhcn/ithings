                "attributes": {
                  "primaryTable": "INPUT_REGISTERS",
                  "startingAddress": "5",
                  "rawType": "INT16"
                },
                "properties": {
                  "value": {
                    "type": "Int16",
                    "readWrite": "R",
                    "defaultValue": "0",
                    "scale": 0.01,
                    "units": "A"
                  }
                }
              },
              {
                "name": "power_total",
