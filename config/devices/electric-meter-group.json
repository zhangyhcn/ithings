            }
          }
        ],
        "events": [
          {
            "identifier": "overload",
            "name": "Overload Alarm",
            "level": "ALERT",
            "output_params": [
              {
                "identifier": "power",
                "name": "Current Power",
                "type": "float"
              }
            ],
            "description": "Triggered when power exceeds threshold"
          }
        ],
        "rules": [
          {
            "identifier": "overload_alarm",
            "name": "Overload Alarm Rule",
            "conditions": [
              {
                "property_identifier": "power",
                "operator": ">",
                "value": 10
              }
            ],
            "condition_logic": "and",
            "actions": [
              {
                "trigger_event": {
                  "event_identifier": "overload",
                  "data": {
                    "power": "{{power}}"
                  }
                }
              }
            ],
            "enabled": true
          }
        ]
      }
    }
  ]
}
