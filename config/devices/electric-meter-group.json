                  { "deviceResource": "voltage_a" },
                  { "deviceResource": "voltage_b" },
                  { "deviceResource": "voltage_c" }
                ]
              },
              {
                "name": "ReadAllCurrents",
                "readWrite": "R",
                "resourceOperations": [
                  { "deviceResource": "current_a" },
                  { "deviceResource": "current_b" },
                  { "deviceResource": "current_c" }
                ]
              },
              {
                "name": "ReadPowerAndEnergy",
                "readWrite": "R",
                "resourceOperations": [
                  { "deviceResource": "power_total" },
                  { "deviceResource": "energy_total" }
                ]
              },
              {
                "name": "ResetEnergy",
                "readWrite": "W",
                "resourceOperations": [
                  { "deviceResource": "reset_register" }
                ]
              },
              {
                "name": "SetThreshold",
                "readWrite": "W",
                "resourceOperations": [
                  { "deviceResource": "threshold_register" }
                ]
              }
            ]
          }
