{
  "tenant_id": "tenant-001",
  "org_id": "org-001",
  "site_id": "site-001",
  "namespace_id": "building-a",
  "remote_transport": {
    "type": "mqtt",
    "broker": "tcp://localhost:1883",
    "client_id": "electric-meter-group"
  },
  "devices": [
    {
      "device_id": "meter-001",
      "device_name": "Main Entrance Electricity Meter",
      "device_type": "electricity-meter",
      "poll_interval_ms": 1000,
      "thing_model": {
        "model_id": "electricity-meter.three-phase.1.0",
        "model_version": "1.0",
        "device_type": "electricity-meter",
        "description": "Three-phase electricity meter",
        "properties": [
          {
            "identifier": "voltage_a",
            "name": "Voltage Phase A",
            "type": "float",
            "unit": "V",
            "access": "R",
            "range": [0, 500],
            "default_value": 0,
            "description": "Phase A voltage"
          },
          {
            "identifier": "voltage_b",
            "name": "Voltage Phase B",
            "type": "float",
            "unit": "V",
            "access": "R",
            "range": [0, 500],
            "default_value": 0,
            "description": "Phase B voltage"
          },
          {
            "identifier": "voltage_c",
            "name": "Voltage Phase C",
            "type": "float",
            "unit": "V",
            "access": "R",
            "range": [0, 500],
            "default_value": 0,
            "description": "Phase C voltage"
          },
          {
            "identifier": "current_a",
            "name": "Current Phase A",
            "type": "float",
            "unit": "A",
            "access": "R",
            "range": [0, 100],
            "default_value": 0,
            "description": "Phase A current"
          },
          {
            "identifier": "current_b",
            "name": "Current Phase B",
            "type": "float",
            "unit": "A",
            "access": "R",
            "range": [0, 100],
            "default_value": 0,
            "description": "Phase B current"
          },
          {
            "identifier": "current_c",
            "name": "Current Phase C",
            "type": "float",
            "unit": "A",
            "access": "R",
            "range": [0, 100],
            "default_value": 0,
            "description": "Phase C current"
          },
          {
            "identifier": "power_total",
            "name": "Total Power",
            "type": "float",
            "unit": "kW",
            "access": "R",
            "range": [0, 1000],
            "default_value": 0,
            "description": "Total active power"
          },
          {
            "identifier": "energy_total",
            "name": "Total Energy",
            "type": "float",
            "unit": "kWh",
            "access": "R",
            "range": [0, 999999],
            "default_value": 0,
            "description": "Total energy consumption"
          }
        ],
        "events": [
          {
            "identifier": "overload",
            "name": "Overload Alarm",
            "level": "ALERT",
            "output_params": [
              {
                "identifier": "power_total",
                "name": "Current Power",
                "type": "float"
              }
            ],
            "description": "Triggered when power exceeds threshold"
          },
          {
            "identifier": "voltage_abnormal",
            "name": "Voltage Abnormal",
            "level": "WARN",
            "output_params": [
              {
                "identifier": "voltage_a",
                "name": "Voltage A",
                "type": "float"
              },
              {
                "identifier": "voltage_b",
                "name": "Voltage B",
                "type": "float"
              },
              {
                "identifier": "voltage_c",
                "name": "Voltage C",
                "type": "float"
              }
            ],
            "description": "Triggered when voltage is out of normal range"
          }
        ],
        "services": [
          {
            "identifier": "reset_energy",
            "name": "Reset Energy",
            "description": "Reset energy accumulator",
            "input_params": [],
            "output_params": [
              {
                "identifier": "success",
                "name": "Success",
                "type": "boolean"
              }
            ]
          },
          {
            "identifier": "set_threshold",
            "name": "Set Alarm Threshold",
            "description": "Set power alarm threshold",
            "input_params": [
              {
                "identifier": "power_threshold",
                "name": "Power Threshold",
                "type": "float",
                "unit": "kW"
              }
            ],
            "output_params": [
              {
                "identifier": "success",
                "name": "Success",
                "type": "boolean"
              }
            ]
          }
        ]
      },
      "rules": [
        {
          "identifier": "overload_alarm",
          "name": "Overload Alarm Rule",
          "conditions": [
            {
              "property_identifier": "power_total",
              "operator": ">",
              "value": 100
            }
          ],
          "condition_logic": "and",
          "actions": [
            {
              "trigger_event": {
                "event_identifier": "overload",
                "data": {
                  "power_total": "{{power_total}}"
                }
              }
            }
          ],
          "enabled": true
        },
        {
          "identifier": "voltage_abnormal_alarm",
          "name": "Voltage Abnormal Alarm",
          "conditions": [
            {
              "property_identifier": "voltage_a",
              "operator": "<",
              "value": 180
            },
            {
              "property_identifier": "voltage_a",
              "operator": ">",
              "value": 260
            }
          ],
          "condition_logic": "or",
          "actions": [
            {
              "trigger_event": {
                "event_identifier": "voltage_abnormal",
                "data": {
                  "voltage_a": "{{voltage_a}}",
                  "voltage_b": "{{voltage_b}}",
                  "voltage_c": "{{voltage_c}}"
                }
              }
            }
          ],
          "enabled": true
        }
      ],
      "driver": {
        "device_id": "meter-001",
        "driver_name": "modbus-driver",
        "driver_type": "modbus",
        "poll_interval_ms": 1000,
        "zmq": {
          "enabled": true,
          "publisher_address": "tcp://*:5555",
          "topic": "modbus/data",
          "high_water_mark": 1000
        },
        "logging": {
          "level": "info",
          "format": "json"
        },
        "custom": {
          "host": "172.25.219.101",
          "port": 502,
          "slave_id": 1,
          "profile": {
            "name": "Three-Phase-Electricity-Meter",
